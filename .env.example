PORT=3000

# Required for AI-generated results. Without this, the app uses a local demo analyzer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: point to your own transcript service. The app falls back to YouTube timedtext captions.
# Expected response: { "transcript": [{ "text": "...", "start": 0, "duration": 4.2 }] }
YOUTUBE_TRANSCRIPT_API_URL=
